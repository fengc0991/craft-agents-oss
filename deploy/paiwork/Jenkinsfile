properties([
  disableConcurrentBuilds(),
  parameters([
    string(name: 'IMAGE_REGISTRY', defaultValue: 'ops-harbor.rabyte.cn/rabyte-data/rabyte-pre/pre/craft-agents-paiwork', description: 'Image repository without tag', trim: true),
    string(name: 'IMAGE_TAG', defaultValue: '', description: 'Optional image tag. Defaults to BUILD_NUMBER', trim: true),
    password(name: 'CRAFT_WEBUI_PASSWORD', description: 'Required WebUI login password'),
    password(name: 'CRAFT_SERVER_TOKEN', description: 'Optional server token. Leave empty to auto-generate'),
    password(name: 'RABYTE_LLM_API_KEY', description: 'Optional Rabyte LLM API key'),
    password(name: 'SEALOS_LLM_API_KEY', description: 'Optional Sealos LLM API key'),
    password(name: 'PAI_OBS_API_KEY', description: 'Optional PaiWork observability API key'),
    string(name: 'PAI_OBS_BASE_URL', defaultValue: 'http://192.168.15.57:30100', description: 'PaiWork observability gateway URL', trim: true),
  ])
])

node {
  timestamps {
    env.DOCKER_BUILDKIT = '1'
    env.K8S_CONTEXT = 'test-saas-acs-new'
    env.K8S_NAMESPACE = 'rabyte-data-pre-data'
    env.K8S_DEPLOYMENT = 'craft-agents-paiwork'

    stage('Checkout') {
      checkout scm
      sh 'git rev-parse --abbrev-ref HEAD && git rev-parse --short=12 HEAD'
    }

    stage('Validate PaiWork Seed') {
      sh '''
        set -eu
        test -f deploy/paiwork/seed/.craft-agent/config.json
        test -d deploy/paiwork/seed/.craft-agent/workspaces/paiwork
        grep -q '"slug"[[:space:]]*:[[:space:]]*"paiwork"' deploy/paiwork/seed/.craft-agent/config.json
        ! grep -q '"slug"[[:space:]]*:[[:space:]]*"fengchao"' deploy/paiwork/seed/.craft-agent/config.json
        ! find deploy/paiwork/seed/.craft-agent -type f \\( -name '.paiobs.env' -o -name 'credentials.enc' -o -name '.server.lock' \\) | grep .
      '''
    }

    stage('Prepare Image') {
      env.GIT_SHA = sh(returnStdout: true, script: 'git rev-parse --short=12 HEAD').trim()
      def tag = params.IMAGE_TAG?.trim() ? params.IMAGE_TAG.trim() : "${env.BUILD_NUMBER}-${env.GIT_SHA}"
      env.IMAGE = "${params.IMAGE_REGISTRY}:${tag}"
      echo "Image: ${env.IMAGE}"
    }

    stage('Build') {
      sh 'IMAGE="$IMAGE" bash deploy/paiwork/scripts/build-image.sh'
    }

    stage('Push') {
      sh 'docker push "$IMAGE"'
    }

    stage('Deploy') {
      sh '''
          set -eu
          export NAMESPACE="$K8S_NAMESPACE"
          export K8S_CONTEXT="$K8S_CONTEXT"
          export IMAGE="$IMAGE"
          export IMAGE_PULL_POLICY=IfNotPresent

          kubectl config get-contexts
          if kubectl config get-contexts "$K8S_CONTEXT" >/dev/null 2>&1; then
            kubectl config use-context "$K8S_CONTEXT"
          else
            echo "Kubeconfig context '$K8S_CONTEXT' not found; using current context: $(kubectl config current-context)"
          fi
          kubectl get namespace "$K8S_NAMESPACE"

          existing_secret_value() {
            key="$1"
            kubectl -n "$K8S_NAMESPACE" get secret craft-agents-paiwork-secret \
              -o "jsonpath={.data.$key}" 2>/dev/null | base64 -d 2>/dev/null || true
          }

          if [ -z "${CRAFT_WEBUI_PASSWORD:-}" ]; then
            echo "CRAFT_WEBUI_PASSWORD is required. Fill it in Build with Parameters." >&2
            exit 1
          fi

          SERVER_TOKEN="${CRAFT_SERVER_TOKEN:-}"
          if [ -z "$SERVER_TOKEN" ]; then
            SERVER_TOKEN="$(existing_secret_value CRAFT_SERVER_TOKEN)"
          fi
          if [ -z "$SERVER_TOKEN" ]; then
            SERVER_TOKEN="$(openssl rand -hex 32)"
          fi

          RABYTE_KEY="${RABYTE_LLM_API_KEY:-}"
          if [ -z "$RABYTE_KEY" ]; then
            RABYTE_KEY="$(existing_secret_value RABYTE_LLM_API_KEY)"
          fi

          SEALOS_KEY="${SEALOS_LLM_API_KEY:-}"
          if [ -z "$SEALOS_KEY" ]; then
            SEALOS_KEY="$(existing_secret_value SEALOS_LLM_API_KEY)"
          fi

          PAI_KEY="${PAI_OBS_API_KEY:-}"
          if [ -z "$PAI_KEY" ]; then
            PAI_KEY="$(existing_secret_value PAI_OBS_API_KEY)"
          fi

          PAI_BASE="${PAI_OBS_BASE_URL:-}"
          if [ -z "$PAI_BASE" ]; then
            PAI_BASE="$(existing_secret_value PAI_OBS_BASE_URL)"
          fi
          if [ -z "$PAI_BASE" ]; then
            PAI_BASE="http://192.168.15.57:30100"
          fi

          secret_file="$(mktemp)"
          trap 'rm -f "$secret_file"' EXIT
          chmod 600 "$secret_file"
          {
            printf 'CRAFT_SERVER_TOKEN=%s\n' "$SERVER_TOKEN"
            printf 'CRAFT_WEBUI_PASSWORD=%s\n' "$CRAFT_WEBUI_PASSWORD"
          } > "$secret_file"

          if [ -n "$RABYTE_KEY" ]; then
            printf 'RABYTE_LLM_API_KEY=%s\n' "$RABYTE_KEY" >> "$secret_file"
          fi
          if [ -n "$SEALOS_KEY" ]; then
            printf 'SEALOS_LLM_API_KEY=%s\n' "$SEALOS_KEY" >> "$secret_file"
          fi
          if [ -n "$PAI_KEY" ]; then
            printf 'PAI_OBS_API_KEY=%s\n' "$PAI_KEY" >> "$secret_file"
            printf 'PAI_OBS_BASE_URL=%s\n' "$PAI_BASE" >> "$secret_file"
          fi

          kubectl -n "$K8S_NAMESPACE" create secret generic craft-agents-paiwork-secret \
            --from-env-file="$secret_file" \
            --dry-run=client -o yaml | kubectl apply -f -

          bash deploy/paiwork/scripts/render-k8s.sh
          kubectl apply -f deploy/paiwork/k8s/rendered.yaml
          kubectl -n "$K8S_NAMESPACE" set image "deployment/$K8S_DEPLOYMENT" webui="$IMAGE"
          kubectl -n "$K8S_NAMESPACE" rollout status "deployment/$K8S_DEPLOYMENT" --timeout=300s
          kubectl -n "$K8S_NAMESPACE" get pods,svc -l app=craft-agents-paiwork
        '''
    }
  }
}
